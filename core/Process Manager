"""
core/process_manager.py

Responsible for listing and terminating OS processes.
Uses psutil for cross-version Windows compatibility.
"""

import psutil


class ProcessNotFoundError(Exception):
    """Raised when no running process matches the given name."""


class ProcessManager:
    """
    Allows the user to terminate a process.
    
    """

    def list_processes(self) -> list[dict]:
        """
        Return a list of running processes as dicts.

        Each dict contains:
            pid  (int)  : process ID
            name (str)  : executable name (e.g. 'Discord.exe')
        """
        processes = []
        for proc in psutil.process_iter(attrs=["pid", "name"]):
            try:
                processes.append(proc.info)
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                # Process may have exited or we lack permissions — skip it.
                continue
        return sorted(processes, key=lambda p: p["name"].lower())

    def find_by_name(self, name: str) -> list[psutil.Process]:
        """
        Return all running processes whose name matches (case-insensitive).

        Args:
            name: Executable name, e.g. 'Discord.exe' or 'discord.exe'.

        Returns:
            List of matching psutil.Process objects (may be empty).
        """
        name_lower = name.lower()
        matches = []
        for proc in psutil.process_iter(attrs=["pid", "name"]):
            try:
                if proc.info["name"].lower() == name_lower:
                    matches.append(proc)
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        return matches

    def kill_by_name(self, name: str) -> int:
        """
        Terminate all processes matching the given name.

        Args:
            name: Executable name to kill, e.g. 'Discord.exe'.

        Returns:
            Number of processes that were successfully terminated.

        Raises:
            ProcessNotFoundError: If no matching process was running.
        """
        targets = self.find_by_name(name)

        if not targets:
            raise ProcessNotFoundError(
                f"No running process found with name '{name}'."
            )

        killed = 0
        for proc in targets:
            try:
                proc.terminate()
                proc.wait(timeout=5)  # wait for graceful exit
                killed += 1
            except psutil.NoSuchProcess:
                # Already gone — count it as killed.
                killed += 1
            except psutil.AccessDenied:
                # Elevated process — skip but don't fail silently.
                pass
            except psutil.TimeoutExpired:
                # Graceful terminate timed out — force kill.
                try:
                    proc.kill()
                    killed += 1
                except (psutil.NoSuchProcess, psutil.AccessDenied):
                    pass

        return killed
